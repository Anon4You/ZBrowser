<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f5f5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Home Page Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#ffffff"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home Page"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <EditText
                android:id="@+id/editHomePage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Enter home page URL"
                android:inputType="textUri"
                android:textSize="14sp"
                android:background="@android:drawable/edit_text"
                android:padding="8dp" />

        </LinearLayout>

        <!-- Browser Settings Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#ffffff"
            android:elevation="2dp"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Browser Settings"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <CheckBox
                android:id="@+id/checkJavaScript"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Enable JavaScript"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/checkImages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Load Images"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/checkZoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable Zoom Controls"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/checkDarkMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dark Mode"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/checkDesktopMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Desktop Mode (Default)"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/checkBlockAds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Block Ads (Basic)"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Search Engine Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#ffffff"
            android:elevation="2dp"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search Engine"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <Spinner
                android:id="@+id/spinnerSearchEngine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="8dp"
                android:background="@android:drawable/btn_dropdown" />

        </LinearLayout>

        <!-- Actions Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#ffffff"
            android:elevation="2dp"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Actions"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Save Settings"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnBookmarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Manage Bookmarks"
                android:textAllCaps="false"
                style="?android:attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/btnClearData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Clear Browsing Data"
                android:textAllCaps="false"
                style="?android:attr/borderlessButtonStyle"
                android:textColor="#d32f2f" />

            <Button
                android:id="@+id/btnAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="About ZBrowser"
                android:textAllCaps="false"
                style="?android:attr/borderlessButtonStyle" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
